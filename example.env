# Environment variables for OCR benchmark v2
# Copy to .env in the repo root and fill in API keys.

# --- LLM provider (pick one path) ---
# Direct Google AI (free tier has low daily quota)
GEMINI_API_KEY=
# GEMINI_OCR_MODEL=gemini-2.5-flash

# OpenRouter (paid credits — use to scale judge / Gemini OCR beyond free tier)
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LLM_PROVIDER=openrouter          # auto-selected when OPENROUTER_API_KEY is set
# GEMINI_JUDGE_MODEL=google/gemini-2.5-flash   # OpenRouter model slug
# GEMINI_JUDGE_RPM_SLEEP=2         # seconds between judge calls (OpenRouter: can be lower)

# Mistral OCR API
MISTRAL_API_KEY=
# MISTRAL_OCR_MODEL=mistral-ocr-latest

# Optional: H100 / extended disk (GPU models)
# OCR_BENCH_ROOT=/amulpfsdata/models/ocr-benchmark
# HF_HOME=/amulpfsdata/models/ocr-benchmark/hf-cache
# HF_HUB_CACHE=/amulpfsdata/models/ocr-benchmark/hf-cache/hub
# OCR_HF_LOCAL_ONLY=1
# CUDA_VISIBLE_DEVICES=6
